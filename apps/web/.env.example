###############################################
# Core Secrets
###############################################
# Generate a random secret: https://generate-secret.vercel.app/32 or: openssl rand -base64 32
AUTH_SECRET=changeme
# Optional dedicated secret for guest cookie signing; falls back to AUTH_SECRET if absent
GUEST_SECRET=

# Cache Encryption Secret (Must match Worker's secret)
# A 32-byte, base64-encoded secret used to derive encryption keys for the client-side cache.
CACHE_ENCRYPTION_SECRET=

# Application public base URL (used for metadata and OAuth redirect host validation)
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
# Some code paths use this alias; keep in sync with BASE_URL above
NEXT_PUBLIC_APP_URL=http://localhost:3000

###############################################
# Edge Cache (Optional)
###############################################
# URL for the Cloudflare Worker. If not set, defaults to /api/cache/encryption-key (Next.js route).
# Dev: http://localhost:8787
# Prod: https://your-worker.your-subdomain.workers.dev
NEXT_PUBLIC_CACHE_ENCRYPTION_URL=

###############################################
# Realtime Gateway (Optional)
###############################################
# WebSocket URL for the realtime gateway. If not set, realtime features are disabled.
# NEXT_PUBLIC_REALTIME_GATEWAY_URL=ws://localhost:3001/ws

###############################################
# Clerk (Authentication)
###############################################
# Obtain from Clerk dashboard (Development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optionally disable social auth buttons ("1" to disable). Omit or set to 0 to enable.
NEXT_PUBLIC_DISABLE_SOCIAL_AUTH=0

###############################################
# OpenRouter (LLM Provider) and Direct Providers
###############################################
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional direct OpenAI access (if you want to call OpenAI directly)
OPENAI_API_KEY=

###############################################
# Google Generative AI (Direct Gemini Provider)
###############################################
# Required only if you want to call Gemini models directly instead of via OpenRouter.
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Alternate env var supported by the app (either works)
GOOGLE_API_KEY=

# Optional xAI (Grok) access
XAI_API_KEY=

# Note: The system automatically routes models to the correct provider
# in this order: Google -> OpenAI -> OpenRouter.
# DEFAULT_CHAT_MODEL=google:gemini-2.5-flash
TITLE_GENERATION_MODEL=
ARTIFACT_GENERATION_MODEL=

# Comma-separated list of model IDs for guest and regular tiers (fallback if DB is empty)
# GUEST_MODELS=google:gemini-2.5-flash
# REGULAR_MODELS=google:gemini-2.5-flash,google:gemini-2.5-pro

###############################################
# Storage: Blob
###############################################
# Vercel Blob RW token (create via Vercel dashboard Storage > Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxx

###############################################
# Redis / KV (Upstash or compatible)
###############################################
REDIS_URL=rediss://:password@host:6379

###############################################
# Admin (Bootstrap single-admin gating)
###############################################
# Set exactly one of these for admin access to /admin. ID takes precedence if both are set.
# ADMIN_USER_ID is the Clerk user id (e.g., user_123...).
ADMIN_USER_ID=
# ADMIN_EMAIL is matched case-insensitively against the signed-in user's email.
ADMIN_EMAIL=

###############################################
# TEST / Playwright (auto-detected; typically not needed manually)
# PLAYWRIGHT=1
# CI_PLAYWRIGHT=1